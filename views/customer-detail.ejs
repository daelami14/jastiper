<div class="container-xl">

<div class="page-header mb-4">

    <div>

        <h2>

            <%= customer.nama %>

        </h2>

        <div class="text-secondary">

            <%= customer.nohp %>

        </div>

    </div>

</div>

<%
    let totalOrder = orders.length;

    let totalQty = 0;

    let totalBelanja = 0;

    orders.forEach(order => {

        totalQty += Number(order.qty || 0);

        totalBelanja += Number(order.subtotal || 0);

    });
%>

<div class="row mb-4">

    <div class="col-md-4">

        <div class="card">

            <div class="card-body text-center">

                <div class="text-secondary">

                    Total Order

                </div>

                <h2>

                    <%= totalOrder %>

                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card">

            <div class="card-body text-center">

                <div class="text-secondary">

                    Total Qty

                </div>

                <h2>

                    <%= totalQty %>

                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card">

            <div class="card-body text-center">

                <div class="text-secondary">

                    Total Belanja

                </div>

                <h2>

                    Rp
                    <%= totalBelanja.toLocaleString('id-ID') %>

                </h2>

            </div>

        </div>

    </div>

</div>

<div class="card">

    <div class="card-header">

        <h3 class="card-title">

            Riwayat Order Customer

        </h3>

    </div>

    <div class="table-responsive">

        <table
            id="customerOrderTable"
            class="table table-striped table-hover">

            <thead>

                <tr>

                    <th>Foto</th>

                    <th>Tanggal</th>

                    <th>Produk</th>

                    <th>Harga</th>

                    <th>Qty</th>

                    <th>Subtotal</th>

                    <th>Status</th>

                    <th>Invoice</th>

                </tr>

            </thead>

            <tbody>

                <% orders.forEach(order => { %>

                <tr>

                    <td>

                        <% if(order.photo_path){ %>

                            <img
                                src="<%= order.photo_path %>"
                                width="60"
                                height="60"
                                class="rounded border"
                                style="object-fit:cover;">

                        <% } else { %>

                            <div
                                class="text-secondary">

                                No Image

                            </div>

                        <% } %>

                    </td>

                    <td>

                        <%= order.created_at %>

                    </td>

                    <td>

                        <strong>

                            <%= order.produk %>

                        </strong>

                    </td>

                    <td>

                        Rp
                        <%= Number(order.harga || 0)
                        .toLocaleString('id-ID') %>

                    </td>

                    <td>

                        <%= order.qty %>

                    </td>

                    <td>

                        Rp
                        <%= Number(order.subtotal || 0)
                        .toLocaleString('id-ID') %>

                    </td>

                    <td>

                        <% if(order.status === 'approved'){ %>

                            <span
                                class="badge bg-green">

                                Approved

                            </span>

                        <% } else if(order.status === 'draft'){ %>

                            <span
                                class="badge bg-yellow">

                                Draft

                            </span>

                        <% } else { %>

                            <span
                                class="badge bg-secondary">

                                <%= order.status %>

                            </span>

                        <% } %>

                    </td>

                    <td>

                        <% if(order.invoice_no){ %>

                            <a
                                href="/invoices/<%= order.invoice_no %>"
                                class="badge bg-blue text-decoration-none">

                                <%= order.invoice_no %>

                            </a>

                        <% } else { %>

                            <span
                                class="badge bg-yellow">

                                Belum Invoice

                            </span>

                        <% } %>

                    </td>

                </tr>

                <% }) %>

            </tbody>

        </table>

    </div>

</div>

</div>

<script>

$(document).ready(function(){

    $('#customerOrderTable').DataTable({

        pageLength: 25,

        responsive: true,

        order: [
            [1, 'desc']
        ]

    });

});

</script>
