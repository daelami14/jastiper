<div class="container-xl">

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h2 class="mb-1">

            <%= invoice.invoice_no %>

        </h2>

        <div class="text-secondary">

            Detail Invoice Customer

        </div>

    </div>

    <div>

        <% if(invoice.status === 'paid'){ %>

            <span class="badge bg-green fs-4">

                PAID

            </span>

        <% } else { %>

            <span class="badge bg-yellow fs-4">

                UNPAID

            </span>

        <% } %>

    </div>

</div>

<div class="row mb-4">

    <div class="col-md-4">

        <div class="card">

            <div class="card-body">

                <div class="text-secondary">

                    Customer

                </div>

                <h3>

                    <%= invoice.nama %>

                </h3>

                <div>

                    <%= invoice.nohp %>

                </div>

            </div>

        </div>

    </div>

    <div class="col-md-2">

        <div class="card">

            <div class="card-body text-center">

                <div class="text-secondary">

                    Produk

                </div>

                <h2>

                    <%= invoice.total_item %>

                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-2">

        <div class="card">

            <div class="card-body text-center">

                <div class="text-secondary">

                    Qty

                </div>

                <h2>

                    <%= invoice.total_qty %>

                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card">

            <div class="card-body text-center">

                <div class="text-secondary">

                    Grand Total

                </div>

                <h2>

                    Rp
                    <%= Number(invoice.grand_total).toLocaleString('id-ID') %>

                </h2>

            </div>

        </div>

    </div>

</div>

<div class="card mb-4">

    <div class="card-body">

        <div class="d-flex gap-2 align-items-center">

            <% if(invoice.wa_sent == 0){ %>

                <button
                    id="btnSendInvoice"
                    class="btn btn-success">

                    Kirim Invoice WA

                </button>

            <% } %>

            <% if(invoice.status !== 'paid'){ %>

                <button
                    id="btnMarkPaid"
                    class="btn btn-primary">

                    Mark Paid

                </button>

            <% } %>

            <div class="ms-auto">

                <strong>WA Status :</strong>

                <% if(invoice.wa_sent == 1){ %>

                    <span class="badge bg-green">

                        Sent

                    </span>

                <% } else { %>

                    <span class="badge bg-red">

                        Not Sent

                    </span>

                <% } %>

            </div>

        </div>

    </div>

</div>

<div class="card">

    <div class="card-header">

        <h3 class="card-title">

            Detail Produk

        </h3>

    </div>

    <div class="table-responsive">

        <table
            id="invoiceItemsTable"
            class="table table-striped table-hover">

            <thead>

                <tr>

                    <th>Foto</th>

                    <th>Produk</th>

                    <th>Harga</th>

                    <th>Qty</th>

                    <th>Subtotal</th>

                </tr>

            </thead>

            <tbody>

                <% items.forEach(item => { %>

                <tr>

                    <td>

                        <% if(item.photo_path){ %>

                            <img
                                src="<%= item.photo_path %>"
                                width="60"
                                class="rounded border">

                        <% } else { %>

                            -

                        <% } %>

                    </td>

                    <td>

                        <%= item.produk %>

                    </td>

                    <td>

                        Rp
                        <%= Number(item.harga).toLocaleString('id-ID') %>

                    </td>

                    <td>

                        <%= item.qty %>

                    </td>

                    <td>

                        Rp
                        <%= Number(item.subtotal).toLocaleString('id-ID') %>

                    </td>

                </tr>

                <% }) %>

            </tbody>

            <tfoot>

                <tr>

                    <th colspan="4" class="text-end">

                        GRAND TOTAL

                    </th>

                    <th>

                        Rp
                        <%= Number(invoice.grand_total).toLocaleString('id-ID') %>

                    </th>

                </tr>

            </tfoot>

        </table>

    </div>

</div>


</div>

<script>

$(document).ready(function(){

    $('#invoiceItemsTable').DataTable({

        pageLength: 10,

        responsive: true,

        order: [[1,'asc']]

    });

});

document
.getElementById("btnSendInvoice")
?.addEventListener(
    "click",
    async () => {

        const res =
            await fetch(
                "/invoices/send/<%= invoice.invoice_no %>",
                {
                    method: "POST"
                }
            );

        const data =
            await res.json();

        if(data.success){

            Swal.fire({
                title: "Berhasil",
                text: "Invoice berhasil dikirim",
                icon: "success"
            });

            location.reload();

        }else{

            Swal.fire({
                title: "Gagal",
                text: "Gagal kirim invoice",
                icon: "error"
            });

        }

    }
);

document
.getElementById("btnMarkPaid")
?.addEventListener(
    "click",
    async () => {

        // Use SweetAlert2 for confirmation instead of browser's native confirm
        const { isConfirmed } = await Swal.fire({
            title: "Konfirmasi",
            text: "Tandai invoice sebagai PAID ?",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            confirmButtonText: "Ya, Tandai",
            cancelButtonText: "Batal"
        });
        
        if(!isConfirmed){
            return;
        }

        const res =
            await fetch(
                "/invoices/paid/<%= invoice.invoice_no %>",
                {
                    method: "POST"
                }
            );

        const data =
            await res.json();

        if(data.success){

            Swal.fire({
                title: "Berhasil",
                text: "Invoice berhasil dibayar",
                icon: "success"
            });



            location.reload();

        }

    }
);

</script>
