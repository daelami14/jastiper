<div class="container-xl">

    <div class="page-header mb-3">

        <h2>

            <%= product.produk %>

        </h2>

    </div>

    <div class="card mb-3">

        <div class="card-body">

            <% if(product.photo_path){ %>

                <img
                    src="<%= product.photo_path %>"
                    width="150"
                    class="img-thumbnail">

            <% } %>

        </div>

    </div>
    <div class="alert alert-info">

    Total Customer Berminat :

    <strong>

        <%= orders.length %>

    </strong>

    </div>

    <div class="alert alert-info">

    Total Qty :

    <strong>

        <%= summary.total_qty %>

    </strong>

    </div>

    

    <div class="card">
         <div class="card-header">

                <button
                    id="btnApprove"
                    class="btn btn-success">

                    Approve Terpilih

                </button>

        </div>

        <div class="card-body">

       <div class="table-responsive">

            <table
                id="customerTable"
                class="table table-striped table-hover">

                <thead>

                    <tr>

                        <th width="50">

                            <input
                                type="checkbox"
                                id="checkAll">

                        </th>

                        <th>Nama</th>

                        <th>No HP</th>

                        <th>Pesan</th>

                        <th>Qty</th>

                        <th>Subtotal</th>

                    </tr>

                </thead>

                <tbody>

                    <% orders.forEach(order => { %>

                    <tr>

                        <td>

                            <input
                                type="checkbox"
                                class="order-check"
                                value="<%= order.customer_msg_id %>">

                        </td>

                        <td>

                            <%= order.nama %>

                        </td>

                        <td>

                            <%= order.nohp %>

                        </td>

                        <td>

                            <%= order.pesan %>

                        </td>

                        <td>

                            <%= order.qty %>

                        </td>

                        <td>

                            Rp
                            <%= Number(order.subtotal)
                            .toLocaleString('id-ID') %>

                        </td>

                    </tr>

                    <% }) %>

                </tbody>

            </table>

        </div>

        </div>

    </div>

</div>

<script>

document
    .getElementById(
        "checkAll"
    )
    .addEventListener(
        "change",
        function () {

            document
                .querySelectorAll(
                    ".order-check"
                )
                .forEach(
                    cb => {

                        cb.checked =
                            this.checked;

                    }
                );

        }
    );

</script>
<script>

document
    .getElementById(
        "btnApprove"
    )
    .addEventListener(
        "click",
        async () => {

            const ids =
                [];

            document
                .querySelectorAll(
                    ".order-checkbox:checked"
                )
                .forEach(
                    cb => {

                        ids.push(
                            cb.value
                        );

                    }
                );

            if (
                ids.length === 0
            ) {

                alert(
                    "Pilih order terlebih dahulu"
                );

                return;

            }

            const res =
                await fetch(
                    "/interest-orders/approve",
                    {

                        method:
                            "POST",

                        headers: {

                            "Content-Type":
                                "application/json"

                        },

                        body:
                            JSON.stringify(
                                { ids }
                            )

                    }
                );

            const data =
                await res.json();

            if (
                data.success
            ) {

                location.reload();

            }

        }
    );



$(document).ready(function(){

    $('#customerTable').DataTable({

        pageLength: 25,

        responsive: true,

        order: [
            [1,'asc']
        ]

    });

});

</script>