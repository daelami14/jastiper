<!doctype html>

<html>

<head>

<meta charset="utf-8">

<meta name="viewport"
      content="width=device-width, initial-scale=1">

<title>Jastiper</title>

<link
    href="/tabler/dist/css/tabler.min.css"
    rel="stylesheet">

<link
rel="stylesheet"
href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css">

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>

<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>
    <%
const current =
    typeof activePage !== "undefined"
    ? activePage
    : "";
%>

<div class="page">

<aside
    class="navbar navbar-vertical navbar-expand-lg">

    <div class="container-fluid">

        <!-- Mobile Toggle -->

        <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#sidebar-menu">

            <span class="navbar-toggler-icon"></span>

        </button>

        <!-- Logo -->

        <!-- Logo -->

        <h1 class="navbar-brand navbar-brand-autodark">

            <div>

                <div
                    style="
                        font-size:20px;
                        font-weight:700;
                    ">

                    Nitip.MamaZZ

                </div>

                <div
                    style="
                        font-size:11px;
                        color:#999;
                    ">

                    Admin Panel

                </div>

            </div>

        </h1>

        <!-- Menu -->

        <div
            class="collapse navbar-collapse"
            id="sidebar-menu">

            <ul class="navbar-nav pt-lg-3">

                <li class="nav-item">

                    <a
                        class="nav-link <%= current === 'dashboard' ? 'active' : '' %>"
                        href="/">

                        <span class="nav-link-icon">

                            📊

                        </span>

                        <span class="nav-link-title">

                            Dashboard

                        </span>

                    </a>

                </li>

                <li class="nav-item">

                    <a
                        class="nav-link <%= current === 'whatsapp' ? 'active' : '' %>"
                        href="/whatsapp">

                        <span class="nav-link-icon">

                            📱

                        </span>

                        <span class="nav-link-title">

                            WhatsApp

                        </span>

                    </a>

                </li>
                <li class="nav-item">

                    <a
                        class="nav-link <%= current === 'interest-orders' ? 'active' : '' %>"
                        href="/interest-orders">

                        <span class="nav-link-icon">

                            ❤️

                        </span>

                        <span class="nav-link-title">

                            Interest Orders

                        </span>

                    </a>

                </li>

               <li class="nav-item">

                    <a
                        class="nav-link <%= current === 'orders' ? 'active' : '' %>"
                        href="/orders">

                        <span class="nav-link-icon">

                            🛒

                        </span>

                        <span class="nav-link-title">

                            Orders

                        </span>

                    </a>

                </li>

                <li class="nav-item">

                    <a
                        class="nav-link <%= current === 'invoices' ? 'active' : '' %>"
                        href="/invoices">

                        <span class="nav-link-icon">

                            🧾

                        </span>

                        <span class="nav-link-title">

                            Invoices

                        </span>

                    </a>

                </li>

                <li class="nav-item">

                    <a
                        class="nav-link <%= current === 'customers' ? 'active' : '' %>"
                        href="/customers">

                        <span class="nav-link-icon">

                            👥

                        </span>

                        <span class="nav-link-title">

                            Customers

                        </span>

                    </a>

                </li>

            </ul>

        </div>

    </div>

</aside>

<div class="page-wrapper">

    <header class="navbar navbar-expand-md d-print-none">

    <div class="container-xl">

        <div>

            <h2 class="page-title">

                <%= pageTitle || "Dashboard" %>

            </h2>

            <% if(pageDescription){ %>

                <div class="text-secondary">

                    <%= pageDescription %>

                </div>

            <% } %>

        </div>

    </div>

</header>

    <div class="page-body">

        <div class="container-xl">

            <%- body %>

        </div>

    </div>

</div>

</div>

<script src="/tabler/dist/js/tabler.min.js"></script>

</body>
</html>
