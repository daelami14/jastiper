<div class="card">

<div class="card-body">

    <div class="table-responsive">

        <table
            id="invoiceTable"
            class="table table-striped table-hover">

            <thead>

                <tr>

                    <th>Invoice</th>

                    <th>Customer</th>

                    <th>Qty</th>

                    <th>Total</th>

                    <th>Status</th>

                    <th>Action</th>

                </tr>

            </thead>

            <tbody>

                <% invoices.forEach(invoice => { %>

                <tr>

                    <td>

                        <%= invoice.invoice_no %>

                    </td>

                    <td>

                        <%= invoice.nama %>

                    </td>

                    <td>

                        <%= invoice.total_qty %>

                    </td>

                    <td>

                        Rp
                        <%= Number(invoice.grand_total)
                        .toLocaleString('id-ID') %>

                    </td>

                    <td>

                        <% if(invoice.status === 'paid'){ %>

                            <span
                                class="badge bg-green">

                                Paid

                            </span>

                        <% } else { %>

                            <span
                                class="badge bg-yellow">

                                Unpaid

                            </span>

                        <% } %>

                    </td>

                    <td>

                        <a
                            href="/invoices/<%= invoice.invoice_no %>"
                            class="btn btn-primary btn-sm">

                            Detail

                        </a>

                    </td>

                </tr>

                <% }) %>

            </tbody>

        </table>

    </div>

</div>

</div>

<script>

$(document).ready(function(){

    $('#invoiceTable').DataTable({

        pageLength: 25,

        responsive: true

    });

});

</script>
