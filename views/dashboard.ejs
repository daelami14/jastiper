<div class="card mb-4">

    <div class="card-body">

        <form
            method="GET"
            action="/"
            class="row g-3 align-items-end">

            <div class="col-md-4">

                <label class="form-label">
                    Dari Tanggal
                </label>

                <input
                    type="date"
                    name="startDate"
                    value="<%= startDate || '' %>"
                    class="form-control">

            </div>

            <div class="col-md-4">

                <label class="form-label">
                    Sampai Tanggal
                </label>

                <input
                    type="date"
                    name="endDate"
                    value="<%= endDate || '' %>"
                    class="form-control">

            </div>

            <div class="col-md-4 d-flex gap-2">

                <button class="btn btn-primary" type="submit">
                    Filter
                </button>

                <a href="/" class="btn btn-outline-secondary">
                    Reset
                </a>

            </div>

        </form>

    </div>

</div>

<div class="row row-deck row-cards mb-4">

    <div class="col-sm-6 col-lg-3">

        <div class="card bg-blue-lt">

            <div class="card-body">

                <div class="text-secondary">

                    Orders

                </div>

                <div class="h1">

                    <%= orderStat.total_order %>

                </div>

            </div>

        </div>

    </div>

    <div class="col-sm-6 col-lg-3">

        <div class="card bg-green-lt">

            <div class="card-body">

                <div class="text-secondary">

                    Customers

                </div>

                <div class="h1">

                    <%= customerStat.total_customer %>

                </div>

            </div>

        </div>

    </div>

    <div class="col-sm-6 col-lg-3">

        <div class="card bg-yellow-lt">

            <div class="card-body">

                <div class="text-secondary">

                    Invoices

                </div>

                <div class="h1">

                    <%= invoiceStat.total_invoice %>

                </div>

            </div>

        </div>

    </div>

    <div class="col-sm-6 col-lg-3">

        <div class="card bg-purple-lt">

            <div class="card-body">

                <div class="text-secondary">

                    Revenue

                </div>

                <div class="h3">

                    Rp
                    <%= Number(revenueStat.revenue)
                    .toLocaleString('id-ID') %>

                </div>

            </div>

        </div>

    </div>

</div>

<div class="row">

    <div class="col-md-6">

        <div class="card">

            <div class="card-header">

                <h3 class="card-title">

                    🔥 Top Product

                </h3>

            </div>

            <table class="table">

                <thead>

                    <tr>

                        <th>Produk</th>

                        <th>Qty</th>

                    </tr>

                </thead>

                <tbody>

                    <% topProducts.forEach(
                        product => {
                    %>

                    <tr>

                        <td>

                            <%= product.produk %>

                        </td>

                        <td>

                            

                                <%= product.total_qty %>

                            

                        </td>

                    </tr>

                    <% }) %>

                </tbody>

            </table>

        </div>

    </div>

    <div class="col-md-6">

        <div class="card">

            <div class="card-header">

                <h3 class="card-title">

                    👑 Top Customer

                </h3>

            </div>

            <table class="table">

                <thead>

                    <tr>

                        <th>Nama</th>

                        <th>Total</th>

                    </tr>

                </thead>

                <tbody>

                    <% topCustomers.forEach(
                        customer => {
                    %>

                    <tr>

                        <td>

                            <%= customer.nama %>

                        </td>

                        <td>

                            Rp
                            <%= Number(
                                customer.total_belanja
                            ).toLocaleString('id-ID') %>

                        </td>

                    </tr>

                    <% }) %>

                </tbody>

            </table>

        </div>

    </div>

    

</div>
<div class="row mt-4">

    <div class="col-md-6">

        <div class="card">

            <div class="card-header">

                <h3 class="card-title">

                    📈 Order Harian

                </h3>

            </div>

            <div class="card-body">

                <canvas
                    id="orderChart">

                </canvas>

            </div>

        </div>

    </div>

    <div class="col-md-6">

        <div class="card">

            <div class="card-header">

                <h3 class="card-title">

                    💰 Revenue Harian

                </h3>

            </div>

            <div class="card-body">

                <canvas
                    id="revenueChart">

                </canvas>

            </div>

        </div>

    </div>

</div>

<script>

// ======================
// ORDER CHART
// ======================

const orderLabels =
<%- JSON.stringify(
    dailyOrders.map(x => {

        const d = new Date(x.tanggal);

        const day =
            String(
                d.getDate()
            ).padStart(
                2,
                '0'
            );

        const month =
            String(
                d.getMonth() + 1
            ).padStart(
                2,
                '0'
            );

        const year =
            d.getFullYear();

        return `${day}-${month}-${year}`;

    })
) %>;

const orderData =
<%- JSON.stringify(
    dailyOrders.map(
        x => x.total
    )
) %>;

new Chart(

    document.getElementById(
        "orderChart"
    ),

    {

        type: "line",

        data: {

            labels:
                orderLabels,

            datasets: [

                {

                    label:
                        "Orders",

                    data:
                        orderData,

                    borderColor:
                        "#206bc4",

                    backgroundColor:
                        "rgba(32,107,196,0.1)",

                    tension: 0.3,

                    fill: true

                }

            ]

        },

        options: {

            responsive: true,

            maintainAspectRatio: false

        }

    }

);

// ======================
// REVENUE CHART
// ======================

const revenueLabels =
<%- JSON.stringify(
    dailyRevenue.map(x => {

        const d = new Date(x.tanggal);

        const day =
            String(
                d.getDate()
            ).padStart(
                2,
                '0'
            );

        const month =
            String(
                d.getMonth() + 1
            ).padStart(
                2,
                '0'
            );

        const year =
            d.getFullYear();

        return `${day}-${month}-${year}`;

    })
) %>;

const revenueData =
<%- JSON.stringify(
    dailyRevenue.map(
        x => x.total
    )
) %>;

new Chart(

    document.getElementById(
        "revenueChart"
    ),

    {

        type: "bar",

        data: {

            labels:
                revenueLabels,

            datasets: [

                {

                    label:
                        "Revenue",

                    data:
                        revenueData,

                    backgroundColor:
                        "#2fb344"

                }

            ]

        },

        options: {

            responsive: true,

            maintainAspectRatio: false,

            scales: {

                y: {

                    ticks: {

                        callback: function(value){

                            return 'Rp ' +
                                Number(value)
                                .toLocaleString(
                                    'id-ID'
                                );

                        }

                    }

                }

            }

        }

    }

);

</script>