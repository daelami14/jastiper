<div class="row row-deck row-cards">
<div class="col-sm-6 col-lg-3">

    <div class="card">

        <div class="card-body">

            <div class="h1">
                <%= totalOrders %>
            </div>

            <div>
                Orders
            </div>

        </div>

    </div>

</div>

<div class="col-sm-6 col-lg-3">

    <div class="card">

        <div class="card-body">

            <div class="h1">
                <%= totalCustomers %>
            </div>

            <div>
                Customers
            </div>

        </div>

    </div>

</div>

<div class="col-sm-6 col-lg-3">

    <div class="card">

        <div class="card-body">

            <div class="h1">
                <%= totalInvoices %>
            </div>

            <div>
                Invoices
            </div>

        </div>

    </div>

</div>

<div class="col-sm-6 col-lg-3">

    <div class="card">

        <div class="card-body">

            <div class="h1">
                Rp <%= revenue %>
            </div>

            <div>
                Revenue
            </div>

        </div>

    </div>

</div>

<div class="row mt-4">

    <div class="col-12">

        <div class="card">

            <div class="card-header">

                <h3 class="card-title">

                    Invoice Terbaru

                </h3>

            </div>

            <div class="table-responsive">

                <table class="table card-table table-vcenter">

                    <thead>

                        <tr>

                            <th>Invoice</th>

                            <th>Customer</th>

                            <th>Total</th>

                            <th>Status</th>

                        </tr>

                    </thead>

                    <tbody>

                        <% recentInvoices.forEach(invoice => { %>

                            <tr>

                                <td>

                                    <%= invoice.invoice_no %>

                                </td>

                                <td>

                                    <%= invoice.nama %>

                                </td>

                                <td>

                                    Rp
                                    <%= Number(invoice.grand_total).toLocaleString('id-ID') %>

                                </td>

                                <td>

                                    <% if(invoice.status === 'paid'){ %>

                                        <span class="badge bg-green">

                                            Paid

                                        </span>

                                    <% } else { %>

                                        <span class="badge bg-yellow">

                                            Unpaid

                                        </span>

                                    <% } %>

                                </td>

                            </tr>

                        <% }) %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

</div>
