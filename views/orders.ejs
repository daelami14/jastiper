document
.getElementById(
    "btnGenerateInvoice"
)
.addEventListener(
    "click",
    async () => {

        const nohps =
            [];

        document
        .querySelectorAll(
            ".customer-checkbox:checked"
        )
        .forEach(
            cb => {

                nohps.push(
                    cb.value
                );

            }
        );

        if (
            nohps.length === 0
        ) {

            alert(
                "Pilih customer"
            );

            return;

        }

        const res =
            await fetch(
                "/generate-invoice",
                {

                    method:
                        "POST",

                    headers: {

                        "Content-Type":
                            "application/json"

                    },

                    body:
                        JSON.stringify(
                            {
                                nohps
                            }
                        )

                }
            );

        const data =
            await res.json();

        if (
            data.success
        ) {

            alert(
                "Invoice berhasil dibuat"
            );

            location.reload();

        }

    }
);

</script>
