<div class="container-xl">

<div class="page-header mb-3">

    <h2>
        Orders
    </h2>

</div>

<div class="card">

    <div class="table-responsive">
        <div class="card-header">

            <button
                type="button"
                id="btnGenerateInvoice"
                class="btn btn-primary">

                Generate Invoice

            </button>

        </div>

        <table class="table table-vcenter">

            <thead>

                <tr>
                     <th>
                        <input
                            type="checkbox"
                            id="checkAll">
                    </th>

                    <th>Tanggal</th>

                    <th>Nama</th>

                    <th>No HP</th>

                    <th>Produk</th>

                    <th>Harga</th>

                    <th>Qty</th>

                    <th>Subtotal</th>

                    <th>Status</th>

                    <th>Foto</th>

                </tr>

            </thead>

            <tbody>

                <% if(orders.length === 0){ %>

                    <tr>

                        <td colspan="9" class="text-center">

                            Belum ada order

                        </td>

                    </tr>

                <% } %>

                <% orders.forEach(order => { %>

                    <tr>
                        <td>

                            <input
                                type="checkbox"
                                class="customer-checkbox"
                                value="<%= order.nohp %>">

                        </td>

                        <td>
                            <%= order.tanggal %>
                        </td>

                        <td>
                            <strong>
                                <%= order.nama %>
                            </strong>
                        </td>

                        <td>
                            <%= order.nohp %>
                        </td>

                        <td>
                            <%= order.produk %>
                        </td>

                        <td>
                            Rp <%= Number(order.harga).toLocaleString('id-ID') %>
                        </td>

                        <td>
                            <%= order.qty %>
                        </td>

                        <td>
                            <strong>
                                Rp <%= Number(order.subtotal).toLocaleString('id-ID') %>
                            </strong>
                        </td>

                        <td>

                            <% if(order.status === 'draft'){ %>

                                <span class="badge bg-yellow">
                                    Draft
                                </span>

                            <% } else if(order.status === 'approved'){ %>

                                <span class="badge bg-green">
                                    Approved
                                </span>

                            <% } else { %>

                                <span class="badge bg-secondary">
                                    <%= order.status %>
                                </span>

                            <% } %>

                        </td>

                        <td>

                            <% if(order.photo_path){ %>

                                <img
                                    src="<%= order.photo_path %>"
                                    width="80"
                                    class="img-thumbnail">

                            <% } else { %>

                                -

                            <% } %>

                        </td>

                    </tr>

                <% }) %>

            </tbody>

        </table>

    </div>

</div>

</div>

<script>

document
    .getElementById(
        "checkAll"
    )
    .addEventListener(
        "change",
        function () {

            document
                .querySelectorAll(
                    ".order-checkbox"
                )
                .forEach(
                    cb => {

                        cb.checked =
                            this.checked;

                    }
                );

        }
    );


