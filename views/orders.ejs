<div class="card">

    <div class="card-body">

        <div class="table-responsive">

            <table
                id="ordersTable"
                class="table table-striped table-hover">

                <thead>

                    <tr>

                        <th>Customer</th>

                        <th>No HP</th>

                        <th>Produk</th>

                        <th>Qty</th>

                        <th>Total</th>

                        <th>Action</th>

                    </tr>

                </thead>

                <tbody>

                    <% orders.forEach(order => { %>

                    <tr>

                        <td>

                            <%= order.nama %>

                        </td>

                        <td>

                            <%= order.nohp %>

                        </td>

                        <td>

                            <%= order.total_produk %>

                        </td>

                        <td>

                            <%= order.total_qty %>

                        </td>

                        <td>

                            Rp
                            <%= Number(order.grand_total)
                            .toLocaleString('id-ID') %>

                        </td>

                        <td>

                            <a
                                href="/orders/<%= encodeURIComponent(order.nohp) %>"
                                class="btn btn-primary btn-sm">

                                Detail

                            </a>

                        </td>

                    </tr>

                    <% }) %>

                </tbody>

            </table>

        </div>

    </div>

</div>
<script>

$(document).ready(function(){

    $('#ordersTable').DataTable({

        pageLength: 25,

        responsive: true,

        order: [
            [4,'desc']
        ]

    });

});

</script>