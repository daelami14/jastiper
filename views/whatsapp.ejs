<div class="row">

<div class="col-md-8">

    <div class="card">

        <div class="card-header">

            <h3 class="card-title">

                WhatsApp Connection

            </h3>

        </div>

        <div class="card-body">

            <p>

                <strong>Status :</strong>

                <span class="badge bg-danger">

                    <%= status %>

                </span>

            </p>

            <p>

                <strong>Phone :</strong>

                <%= phone %>

            </p>

            <% if (qr) { %>

                <img
                    src="<%= qr %>"
                    width="300">

            <% } else { %>

                <div
                    class="text-muted">

                    QR belum tersedia

                </div>

            <% } %>

        </div>

    </div>

</div>

</div>
