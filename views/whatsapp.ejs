<div class="row">

<div class="col-md-8">

    <div class="card">

        <div class="card-header">

            <h3 class="card-title">

                WhatsApp Connection

            </h3>

        </div>

        <div class="card-body">

            <% if(status === "Connected"){ %>

                <div
                    class="alert alert-success">

                    🟢 WhatsApp Connected

                </div>

            <% } else { %>

                <div
                    class="alert alert-danger">

                    🔴 WhatsApp Disconnected

                </div>

            <% } %>

            <div
                class="d-flex gap-2">

                <button
                    onclick="location.reload()"
                    class="btn btn-primary">

                    Refresh

                </button>

            </div>

            <div class="mt-4">

                <div class="text-secondary mb-2">
                    Nomor WhatsApp
                </div>

                <div class="h3">
                    <%= phone || "-" %>
                </div>

            </div>

            <% if(qr){ %>

                <div class="mt-4 text-center">

                    <div class="text-secondary mb-3">
                        Scan QR ini dengan akun WhatsApp Anda
                    </div>

                    <img
                        src="<%= qr %>"
                        alt="QR WhatsApp"
                        class="img-fluid"
                        style="max-width:280px;">

                </div>

            <% } else if(status !== "Connected") { %>

                <div class="alert alert-warning mt-4 mb-0">
                    QR sedang dipersiapkan. Refresh halaman ini beberapa detik lagi bila belum muncul.
                </div>

            <% } %>

        </div>

    </div>

</div>

<div class="col-md-4">

    <div class="card bg-green-lt">

        <div class="card-body text-center">

            <div class="text-secondary">

                Order Hari Ini

            </div>

            <h1>

                <%= orderToday ?? 0 %>

            </h1>

        </div>

    </div>

</div>


</div>

<div class="row mt-3">


<div class="col-md-6">

    <div class="card bg-blue-lt">

        <div class="card-body text-center">

            <div class="text-secondary">

                Interest Order

            </div>

            <h1>

                <%= interestToday ?? 0 %>

            </h1>

        </div>

    </div>

</div>

<div class="col-md-6">

    <div class="card bg-yellow-lt">

        <div class="card-body text-center">

            <div class="text-secondary">

                Status

            </div>

            <h1>

                <%= status === "Connected"
                    ? "ONLINE"
                    : "OFFLINE"
                %>

            </h1>

        </div>

    </div>

</div>


</div>
